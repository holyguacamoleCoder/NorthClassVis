OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# 单 Agent 多模型路由（未设置时回退到 OPENAI_MODEL / OPENAI_MODEL_MAIN）
# OPENAI_MODEL_MAIN=gpt-4o
# OPENAI_MODEL_CONSULT=gpt-4o-mini
# OPENAI_MODEL_PRODUCE=gpt-4o
# OPENAI_MODEL_BINDING=gpt-4o-mini
# OPENAI_MODEL_COMPACT=gpt-4o-mini

# Langfuse（https://cloud.langfuse.com 或自托管）
LANGFUSE_ENABLED=1
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# 默认 1：不向 Langfuse 上传完整对话正文（仅长度摘要）
LANGFUSE_REDACT_CONTENT=1